# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Sync pipeline — generate with: openssl rand -hex 32
# Used to authenticate the /api/sync endpoint (Vercel cron + admin button)
SYNC_SECRET=your-random-secret-here
